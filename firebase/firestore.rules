rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Breweries: anyone can read, only claimed owner can write
    match /breweries/{breweryId} {
      allow read: if true;
      allow write: if request.auth != null
        && resource.data.claimedBy == request.auth.uid;
    }

    // Users: owner can read/write own doc, others can read public fields
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;

      // Stamps: only created via Cloud Functions (verifyStamp)
      match /stamps/{stampId} {
        allow read: if request.auth != null;
        allow create: if false; // Enforced server-side only
        allow update, delete: if request.auth.uid == userId;
      }
    }

    // Trails: authenticated users can create, only creator can edit
    match /trails/{trailId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == resource.data.createdBy;
    }
  }
}
